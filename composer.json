{
    "name": "joao-aschenbrenner/schf-migration",
    "description": "SCHF Migration Framework — pipeline universal de migracao de dados",
    "type": "project",
    "license": "MIT",
    "require": {
        "laravel/framework": "^12.0",
        "php": "^8.2",
        "joao-aschenbrenner/schf-sdk": "@dev"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "App\\": "backend/app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../schf-sdk",
            "options": { "symlink": false }
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ]
    }
}
