{
    "name": "joao-aschenbrenner/schf-migration",
    "description": "SCHF Migration Framework — pipeline universal de migracao de dados",
    "type": "project",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "joao-aschenbrenner/schf-sdk": "@dev"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "backend/app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "repositories": [
        {
            "type": "path",
            "url": "../schf-sdk",
            "options": { "symlink": false }
        }
    ],
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}
